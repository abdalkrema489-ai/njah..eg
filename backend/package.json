{
  "name": "najah-backend",
  "version": "1.0.0",
  "description": "Production backend for Najah Egyptian School Platform",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "share": "set ENV_FILE=.env.ngrok && nodemon src/server.js",
    "migrate": "node -e \"require('./src/config/postgres').connectPostgres().then(()=>process.exit(0))\"",
    "seed": "node src/config/seed.js",
    "lint": "eslint src/ --ext .js --fix",
    "test": "jest --forceExit --detectOpenHandles --testTimeout=30000"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.15.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.0.1",
    "firebase-admin": "^12.0.0",
    "google-auth-library": "^9.4.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^3.3.11",
    "node-cron": "^3.0.3",
    "node-fetch": "^2.7.0",
    "nodemailer": "^6.9.7",
    "openai": "^4.104.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.3",
    "redis": "^4.6.11",
    "sharp": "^0.33.1",
    "socket.io": "^4.6.1",
    "twilio": "^6.0.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "ws": "^8.20.0",
    "youtube-transcript": "1.2.1"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  }
}
