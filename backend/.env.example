# ════════════════════════════════════════
# NAJAH PLATFORM — Backend Environment
# Copy to .env and fill in every value
# ════════════════════════════════════════

NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# ── Frontend (React) ──
REACT_APP_API_URL=https://njaheg-production.up.railway.app/api
REACT_APP_SOCKET_URL=https://njaheg-production.up.railway.app
REACT_APP_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# ── JWT ──
JWT_SECRET=replace_with_64_char_random_string_abcdefghijklmnopqrstuvwxyz123456
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_different_64_char_random_string_zyxwvutsrqponm
JWT_REFRESH_EXPIRES_IN=30d

# ── PostgreSQL ──
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@localhost:5432/najah_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=najah_db
DB_USER=postgres
DB_PASSWORD=YOUR_DB_PASSWORD
DB_SSL=false

# ── MongoDB ──
MONGODB_URI=mongodb://localhost:27017/najah_chat
MONGO_PASSWORD=YOUR_MONGO_PASSWORD

# ── Redis (Local or Upstash) ──
REDIS_URL=rediss://your-upstash-endpoint.upstash.io:6379
REDIS_PASSWORD=your_upstash_token_here

# ── Google OAuth 2.0 ──
REACT_APP_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── Firebase Storage ──
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your_firebase_private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_FIREBASE_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# ── OpenAI / AI ──
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MAX_TOKENS=2000

# ── Email (SMTP) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Najah Platform <noreply@najah.edu.eg>

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── App Settings ──
MAX_FILE_SIZE_MB=200
BCRYPT_ROUNDS=12

# ─── Security (Required for production) ────────────────
# PAYMOB_HMAC_SECRET: Get from Paymob Dashboard → Developer → HMAC Secret
PAYMOB_HMAC_SECRET=
# ALLOWED_ORIGINS: Comma-separated list of allowed frontend URLs in production
# Example: https://yourapp.vercel.app,https://www.yourapp.com
ALLOWED_ORIGINS=https://njaheg-theta.vercel.app

# ─── Paymob Payment Integrations ────────────────────────
PAYMOB_CARD_INTEGRATION_ID=
PAYMOB_WALLET_INTEGRATION_ID=
PAYMOB_FAWRY_INTEGRATION_ID=
PAYMOB_IFRAME_ID=

# ─── Twilio (SMS Notifications) ─────────────────────────
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+12025550000

# ─── Daily.co (Live Sessions / Video) ───────────────────
# Get your key from: https://dashboard.daily.co/developers
DAILY_API_KEY=
DAILY_API_BASE=https://api.daily.co/v1

# ─── Monitoring & Error Tracking ────────────────────────
# Backend error tracking (https://sentry.io)
SENTRY_DSN=
# Frontend error tracking (add to .env in /frontend)
VITE_SENTRY_DSN=

# ─── Feature Flags ──────────────────────────────────────
ENABLE_GOOGLE_AUTH=true
ENABLE_PAYMOB=true
PLATFORM_FEE_PERCENT=5

# ─── PWA Push Notifications (VAPID) ─────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── Mem0 — Persistent AI Memory ────────────────────────────
# Set MEM0_ENABLED=true to activate cross-session student memory
MEM0_ENABLED=true          # ← فعّل الذاكرة الدائمة (true بدل false)
# Cloud version (better): get key from https://app.mem0.ai
MEM0_API_KEY=
# If MEM0_API_KEY is empty, uses local open-source mode (no key needed)

# ─── Ollama — Local AI Fallback ─────────────────────────────
# Runs local models on the server for free (no external API calls)
# Inside Docker: http://ollama:11434 | Locally: http://localhost:11434
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=gemma2:2b
# Alternative models (size): llama3.2:3b (2GB), phi3:mini (2.2GB)
# After docker-compose up, run: docker exec najah-ollama ollama pull gemma2:2b

# ─── MarkItDown — Enhanced File Text Extraction ──────────────
# Microsoft MarkItDown: extracts text from PDF/Word/PPT (incl. scanned)
# Inside Docker: http://markitdown:5001 | Locally: http://localhost:5001
MARKITDOWN_URL=http://markitdown:5001

# ─── Push Notifications — FCM (Firebase Cloud Messaging) ─────
# Get server key from: Firebase Console → Project Settings → Cloud Messaging
FIREBASE_SERVER_KEY=
# FCM v1 API — recommended (uses OAuth2 service account)
FIREBASE_PROJECT_ID=najah-app
# Path to service-account JSON (download from Firebase Console → Service Accounts)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ─── Android Build (CI/CD) ────────────────────────────────────
# Override at build time (GitHub Actions / Railway / Bitrise)
KEYSTORE_PASSWORD=
KEY_ALIAS=najah
KEY_PASSWORD=
